{
  "name": "@zhihu-ai-summary/extension",
  "version": "2.2.0",
  "description": "知乎中的文章、问题和回答提供 AI 智能总结功能",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:no-open": "wxt --debug --level info",
    "build": "wxt prepare && wxt build",
    "build:chrome": "wxt prepare && wxt build -b chrome",
    "build:firefox": "wxt prepare && wxt build -b firefox",
    "build:safari": "wxt prepare && wxt build -b safari",
    "build:all": "wxt prepare && wxt build -b chrome && wxt build -b firefox && wxt build -b safari",
    "zip:chrome": "wxt prepare && wxt zip -b chrome",
    "zip:firefox": "wxt prepare && wxt zip -b firefox",
    "zip:safari": "wxt prepare && wxt zip -b safari",
    "zip:all": "wxt prepare && wxt zip -b chrome && wxt zip -b firefox && wxt zip -b safari",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true }); require('fs').rmSync('.wxt', { recursive: true, force: true });\"",
    "postinstall": "wxt prepare"
  },
  "keywords": [
    "zhihu",
    "ai",
    "summary",
    "chrome-extension"
  ],
  "author": "Summer121",
  "license": "MIT",
  "dependencies": {
    "@zhihu-ai-summary/core": "workspace:*",
    "@zhihu-ai-summary/ui": "workspace:*",
    "preact": "^10.19.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.7.0",
    "@types/chrome": "^0.0.254",
    "typescript": "^5.3.3",
    "wxt": "^0.20.18"
  },
  "homepage": "https://github.com/summer-8848/zhihu-ai-summary",
  "repository": "https://github.com/summer-8848/zhihu-ai-summary",
  "bugs": "https://github.com/summer-8848/zhihu-ai-summary/issues"
}
