{
  "type": "module",
  "name": "zhihu-ai-summary",
  "version": "2.3.0",
  "private": true,
  "description": "知乎中的文章、问题和回答提供 AI 智能总结功能",
  "scripts": {
    "dev:userscript": "pnpm --filter userscript dev",
    "dev:userscript:watch": "pnpm --filter userscript dev:watch",
    "dev:userscript:serve": "cd packages/userscript/dist && npx http-server -p 8080 --cors",
    "dev:extension": "pnpm --filter extension dev:no-open",
    "build": "pnpm -r build",
    "build:userscript": "pnpm --filter userscript build",
    "build:extension": "pnpm --filter extension build",
    "build:extension:chrome": "pnpm --filter extension build:chrome",
    "build:extension:firefox": "pnpm --filter extension build:firefox",
    "build:extension:safari": "pnpm --filter extension build:safari",
    "build:extension:all": "pnpm --filter extension build:all",
    "zip:extension:chrome": "pnpm --filter extension zip:chrome",
    "zip:extension:firefox": "pnpm --filter extension zip:firefox",
    "zip:extension:safari": "pnpm --filter extension zip:safari",
    "zip:extension:all": "pnpm --filter extension zip:all",
    "release:extension": "pnpm zip:extension:all",
    "clean": "pnpm -r clean",
    "release": "commit-and-tag-version",
    "release:dry": "commit-and-tag-version --dry-run",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix"
  },
  "keywords": [
    "zhihu",
    "ai",
    "summary",
    "userscript",
    "extension"
  ],
  "author": "Summer121",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@types/node": "25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "commit-and-tag-version": "12.6.1",
    "eslint": "9.39.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0"
  },
  "homepage": "https://github.com/summer-8848/zhihu-ai-summary",
  "repository": "https://github.com/summer-8848/zhihu-ai-summary",
  "bugs": "https://github.com/summer-8848/zhihu-ai-summary/issues"
}
